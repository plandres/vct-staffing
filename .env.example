# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXX...

# Required for MCP server (admin operations, bypasse RLS — ne jamais exposer au client)
SUPABASE_SERVICE_ROLE_KEY=eyXXXX...

# MCP Server — clé API pour protéger le endpoint /api/{transport}
# Générer avec: openssl rand -hex 32
MCP_API_KEY=votre_cle_secrete_ici

# Microsoft Azure OAuth (required for SSO)
# Obtenir depuis Azure AD > App Registrations > ton app
# Ces valeurs sont à configurer dans Supabase Dashboard > Authentication > Providers > Azure
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
